# Phase 5: edit and render defaults
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
OUTPUT_ASPECT_RATIO=9:16
OUTPUT_FPS=24
OUTPUT_VIDEO_CODEC=libx264
OUTPUT_AUDIO_CODEC=aac
