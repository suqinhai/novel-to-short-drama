QC_FRAME_SAMPLE_PER_SHOT=3
QC_BLOCKING_SCORE=60
QC_WARNING_SCORE=80
QC_MAX_BLACK_SECONDS=1
QC_MAX_SILENCE_SECONDS=2
QC_DURATION_TOLERANCE_PERCENT=10
QC_AUDIO_VIDEO_DRIFT_MS=200

# Phase 5: publication. Real upload remains opt-in and disabled by default.
