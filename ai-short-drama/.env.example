ENABLE_INTRO=false
ENABLE_OUTRO=false
BURN_SUBTITLES=true
GENERATE_CLEAN_MASTER=true
GENERATE_PREVIEW_MASTER=true

# Phase 5: QC. Empty vision model disables paid vision calls.
QC_TECHNICAL_ENABLED=true
QC_SUBTITLE_ENABLED=true
QC_CONTENT_ENABLED=true
QC_COMPLIANCE_ENABLED=true
QC_VISION_MODEL=
