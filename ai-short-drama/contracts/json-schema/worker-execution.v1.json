{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-short-drama.local/contracts/worker-execution.v1.json",
  "title": "Worker Execution V1",
  "description": "Claim-token-fenced worker write envelope. Every checkpoint or terminal publish must run in the same transaction as assert_operation_claim.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "operation_id", "trace_id", "claim_token", "lease_owner", "lease_expires_at", "action", "payload"],
  "properties": {
    "contract_version": {"const": "2.0"},
    "operation_id": {"$ref": "#/$defs/id"},
    "trace_id": {"$ref": "#/$defs/id"},
    "claim_token": {"type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"},
    "lease_owner": {"type": "string", "minLength": 1, "maxLength": 255},
    "lease_expires_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"},
    "action": {"enum": ["checkpoint", "complete", "fail"]},
    "payload": {"type": "object"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    }
  }
}
