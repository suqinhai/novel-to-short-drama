{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-short-drama.local/contracts/adaptation-spec.v1.json",
  "title": "Adaptation Specification V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_version_id",
    "scope",
    "platform",
    "audience_profile",
    "target_episode_count",
    "episode_duration_seconds",
    "rules"
  ],
  "properties": {
    "schema_version": {"const": "adaptation-spec.v1"},
    "source_version_id": {"$ref": "#/$defs/id"},
    "ir_revision_id": {"$ref": "#/$defs/id"},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "chapter_ids", "story_arc_revision_ids"],
      "properties": {
        "mode": {"enum": ["union", "intersection", "chapters_only", "arcs_only"]},
        "chapter_ids": {"type": "array", "uniqueItems": true, "maxItems": 10000, "items": {"$ref": "#/$defs/id"}},
        "story_arc_revision_ids": {"type": "array", "uniqueItems": true, "maxItems": 10000, "items": {"$ref": "#/$defs/id"}}
      },
      "allOf": [
        {
          "if": {"required": ["mode"], "properties": {"mode": {"const": "chapters_only"}}},
          "then": {"properties": {"chapter_ids": {"type": "array", "minItems": 1}, "story_arc_revision_ids": {"type": "array", "maxItems": 0}}}
        },
        {
          "if": {"required": ["mode"], "properties": {"mode": {"const": "arcs_only"}}},
          "then": {"properties": {"chapter_ids": {"type": "array", "maxItems": 0}, "story_arc_revision_ids": {"type": "array", "minItems": 1}}}
        },
        {
          "if": {"required": ["mode"], "properties": {"mode": {"const": "union"}}},
          "then": {
            "anyOf": [
              {"properties": {"chapter_ids": {"type": "array", "minItems": 1}}},
              {"properties": {"story_arc_revision_ids": {"type": "array", "minItems": 1}}}
            ]
          }
        },
        {
          "if": {"required": ["mode"], "properties": {"mode": {"const": "intersection"}}},
          "then": {"properties": {"chapter_ids": {"type": "array", "minItems": 1}, "story_arc_revision_ids": {"type": "array", "minItems": 1}}}
        }
      ]
    },
    "platform": {"type": "string", "minLength": 1, "maxLength": 200},
    "audience_profile": {"type": "object"},
    "target_episode_count": {"type": "integer", "minimum": 1, "maximum": 1000},
    "episode_duration_seconds": {"type": "integer", "minimum": 1, "maximum": 7200},
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {"$ref": "#/$defs/rule"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_type", "enforcement", "target_type", "priority", "parameters"],
      "properties": {
        "rule_type": {"enum": ["must_preserve", "merge_allowed", "must_not_change", "omit_allowed", "transform_required"]},
        "enforcement": {"enum": ["hard", "soft"]},
        "target_type": {"enum": ["entity", "fact", "event", "story_arc", "chapter", "attribute", "free_text"]},
        "target_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "priority": {"type": "integer", "minimum": 0},
        "parameters": {"type": "object"},
        "rationale": {"type": "string", "maxLength": 4000}
      },
      "allOf": [
        {
          "if": {"required": ["target_type"], "properties": {"target_type": {"const": "free_text"}}},
          "then": {"properties": {"target_id": {"type": "null"}}},
          "else": {"required": ["target_id"], "properties": {"target_id": {"$ref": "#/$defs/id"}}}
        },
        {
          "if": {"required": ["target_type"], "properties": {"target_type": {"const": "attribute"}}},
          "then": {
            "properties": {
              "parameters": {
                "type": "object",
                "required": ["owner_type", "owner_id", "path"],
                "properties": {
                  "owner_type": {"enum": ["entity", "fact", "event", "story_arc", "chapter"]},
                  "owner_id": {"$ref": "#/$defs/id"},
                  "path": {"type": "string", "minLength": 1, "maxLength": 500}
                }
              }
            }
          }
        }
      ]
    }
  }
}
