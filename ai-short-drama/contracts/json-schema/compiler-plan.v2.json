{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-short-drama.local/contracts/compiler-plan.v2.json",
  "title": "Reviewable Adaptation Compiler Plan V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "compiler_run_id", "episodes", "diagnostics", "validation"],
  "properties": {
    "schema_version": {"const": "compiler-plan.v2"},
    "compiler_run_id": {"$ref": "#/$defs/id"},
    "episodes": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"$ref": "#/$defs/episode"}},
    "diagnostics": {"type": "array", "maxItems": 10000, "items": {"$ref": "#/$defs/diagnostic"}},
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hard_rules_satisfied", "event_references_valid", "timeline_valid", "causality_valid", "foreshadowing_valid", "duration_valid"],
      "properties": {
        "hard_rules_satisfied": {"type": "boolean"},
        "event_references_valid": {"type": "boolean"},
        "timeline_valid": {"type": "boolean"},
        "causality_valid": {"type": "boolean"},
        "foreshadowing_valid": {"type": "boolean"},
        "duration_valid": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"},
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_revision_id", "sequence_number", "usage_mode", "rule_ids"],
      "properties": {
        "event_revision_id": {"$ref": "#/$defs/id"},
        "sequence_number": {"type": "integer", "minimum": 1},
        "usage_mode": {"enum": ["preserve", "merge", "transform", "reference"]},
        "merge_group_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "rule_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episode_number", "title", "logline", "estimated_duration_seconds", "opening_hook", "ending_hook",
        "source_event_ids", "source_chapter_ids", "added_adaptation_content", "merged_content", "deviation_notes", "event_assignments"
      ],
      "properties": {
        "episode_number": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1, "maxLength": 500},
        "logline": {"type": "string", "maxLength": 4000},
        "estimated_duration_seconds": {"type": "integer", "minimum": 1, "maximum": 7200},
        "opening_hook": {"type": "string", "maxLength": 4000},
        "ending_hook": {"type": "string", "maxLength": 4000},
        "continuity_in": {"type": "array", "items": {"type": "string", "maxLength": 2000}},
        "continuity_out": {"type": "array", "items": {"type": "string", "maxLength": 2000}},
        "source_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "source_chapter_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "added_adaptation_content": {"type": "array", "items": {"$ref": "#/$defs/addedContent"}},
        "merged_content": {"type": "array", "items": {"$ref": "#/$defs/mergedContent"}},
        "deviation_notes": {"type": "array", "items": {"$ref": "#/$defs/deviation"}},
        "event_assignments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/assignment"}}
      }
    },
    "addedContent": {
      "type": "object", "additionalProperties": false,
      "required": ["content_id", "description", "reason", "rule_ids"],
      "properties": {
        "content_id": {"$ref": "#/$defs/id"}, "description": {"type": "string", "minLength": 1, "maxLength": 4000},
        "reason": {"type": "string", "minLength": 1, "maxLength": 4000},
        "rule_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "mergedContent": {
      "type": "object", "additionalProperties": false,
      "required": ["merge_group_id", "source_event_ids", "description", "rule_ids"],
      "properties": {
        "merge_group_id": {"$ref": "#/$defs/id"},
        "source_event_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "description": {"type": "string", "minLength": 1, "maxLength": 4000},
        "rule_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "deviation": {
      "type": "object", "additionalProperties": false,
      "required": ["deviation_id", "kind", "description", "source_event_ids", "rule_ids"],
      "properties": {
        "deviation_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["addition", "merge", "transform", "omission", "reorder"]},
        "description": {"type": "string", "minLength": 1, "maxLength": 4000},
        "source_event_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "rule_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "diagnostic": {
      "type": "object", "additionalProperties": false, "required": ["severity", "code", "message"],
      "properties": {
        "severity": {"enum": ["info", "warning", "error", "blocking"]},
        "code": {"type": "string", "minLength": 1, "maxLength": 200},
        "message": {"type": "string", "minLength": 1, "maxLength": 4000},
        "entity_type": {"type": ["string", "null"], "maxLength": 200},
        "entity_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "details": {"type": "object"}
      }
    }
  }
}
