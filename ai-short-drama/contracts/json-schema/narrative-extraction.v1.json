{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-short-drama.local/contracts/narrative-extraction.v1.json",
  "title": "Narrative IR Extraction V1",
  "description": "Bounded chapter/window model output. The producer computes stable IDs and fingerprints after validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entities", "facts", "event_relations", "story_arcs"],
  "properties": {
    "schema_version": {"const": "narrative-extraction.v1"},
    "entities": {
      "type": "array",
      "maxItems": 500,
      "items": {"$ref": "#/$defs/entity"}
    },
    "facts": {
      "type": "array",
      "maxItems": 2000,
      "items": {"$ref": "#/$defs/fact"}
    },
    "event_relations": {
      "type": "array",
      "maxItems": 5000,
      "items": {"$ref": "#/$defs/eventRelation"}
    },
    "story_arcs": {
      "type": "array",
      "maxItems": 200,
      "items": {"$ref": "#/$defs/storyArc"}
    }
  },
  "$defs": {
    "localId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_version_id",
        "chapter_id",
        "chapter_revision_id",
        "start_utf8_byte",
        "end_utf8_byte",
        "start_codepoint",
        "end_codepoint",
        "quote",
        "quote_hash",
        "confidence"
      ],
      "properties": {
        "source_version_id": {"$ref": "#/$defs/localId"},
        "chapter_id": {"$ref": "#/$defs/localId"},
        "chapter_revision_id": {"$ref": "#/$defs/localId"},
        "start_utf8_byte": {"type": "integer", "minimum": 0},
        "end_utf8_byte": {"type": "integer", "minimum": 1},
        "start_codepoint": {"type": "integer", "minimum": 0},
        "end_codepoint": {"type": "integer", "minimum": 1},
        "start_paragraph": {"type": "integer", "minimum": 1},
        "end_paragraph": {"type": "integer", "minimum": 1},
        "quote": {"type": "string", "minLength": 1, "maxLength": 4000},
        "quote_hash": {"$ref": "#/$defs/sha256"},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "entity_type", "canonical_name", "aliases", "source"],
      "properties": {
        "local_id": {"$ref": "#/$defs/localId"},
        "entity_type": {"enum": ["character", "location", "organization", "object", "concept"]},
        "canonical_name": {"type": "string", "minLength": 1, "maxLength": 500},
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "attributes": {"type": "object"},
        "source": {"$ref": "#/$defs/source"}
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_local_id", "role", "source"],
      "properties": {
        "entity_local_id": {"$ref": "#/$defs/localId"},
        "role": {"type": "string", "minLength": 1, "maxLength": 200},
        "state": {"type": "object"},
        "source": {"$ref": "#/$defs/source"}
      }
    },
    "fact": {
      "oneOf": [
        {"$ref": "#/$defs/eventFact"},
        {"$ref": "#/$defs/stateFact"},
        {"$ref": "#/$defs/timelineFact"},
        {"$ref": "#/$defs/foreshadowFact"},
        {"$ref": "#/$defs/genericFact"}
      ]
    },
    "factBase": {
      "type": "object",
      "required": ["local_id", "fact_kind", "statement", "source"],
      "properties": {
        "local_id": {"$ref": "#/$defs/localId"},
        "fact_kind": {"enum": ["event", "character_state", "timeline", "foreshadowing", "world_rule", "relationship"]},
        "statement": {"type": "string", "minLength": 1, "maxLength": 8000},
        "source": {"$ref": "#/$defs/source"},
        "supporting_sources": {
          "type": "array",
          "maxItems": 50,
          "items": {"$ref": "#/$defs/source"}
        }
      }
    },
    "eventFact": {
      "allOf": [
        {"$ref": "#/$defs/factBase"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["local_id", "fact_kind", "statement", "source", "event"],
          "properties": {
            "local_id": true,
            "fact_kind": {"const": "event"},
            "statement": true,
            "source": true,
            "supporting_sources": true,
            "event": {
              "type": "object",
              "additionalProperties": false,
              "required": ["event_type", "summary", "narrative_order", "participants"],
              "properties": {
                "event_type": {"type": "string", "minLength": 1, "maxLength": 200},
                "summary": {"type": "string", "minLength": 1, "maxLength": 8000},
                "narrative_order": {"type": "number"},
                "temporal_expression": {"type": ["string", "null"], "maxLength": 1000},
                "location_entity_local_id": {"anyOf": [{"$ref": "#/$defs/localId"}, {"type": "null"}]},
                "importance": {"$ref": "#/$defs/confidence"},
                "participants": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/participant"}}
              }
            }
          }
        }
      ]
    },
    "stateFact": {
      "allOf": [
        {"$ref": "#/$defs/factBase"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["local_id", "fact_kind", "statement", "source", "character_state"],
          "properties": {
            "local_id": true,
            "fact_kind": {"const": "character_state"},
            "statement": true,
            "source": true,
            "supporting_sources": true,
            "character_state": {
              "type": "object",
              "additionalProperties": false,
              "required": ["character_entity_local_id", "dimension", "before", "after", "sequence_number"],
              "properties": {
                "character_entity_local_id": {"$ref": "#/$defs/localId"},
                "dimension": {"type": "string", "minLength": 1, "maxLength": 200},
                "before": {"type": "object"},
                "after": {"type": "object"},
                "trigger_event_local_id": {"anyOf": [{"$ref": "#/$defs/localId"}, {"type": "null"}]},
                "sequence_number": {"type": "number"}
              }
            }
          }
        }
      ]
    },
    "timelineFact": {
      "allOf": [
        {"$ref": "#/$defs/factBase"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["local_id", "fact_kind", "statement", "source", "timeline"],
          "properties": {
            "local_id": true,
            "fact_kind": {"const": "timeline"},
            "statement": true,
            "source": true,
            "supporting_sources": true,
            "timeline": {
              "type": "object",
              "additionalProperties": false,
              "required": ["temporal_expression", "certainty"],
              "properties": {
                "temporal_expression": {"type": "string", "minLength": 1, "maxLength": 2000},
                "normalized_time": {"type": "object"},
                "timeline_order": {"type": ["number", "null"]},
                "certainty": {"enum": ["exact", "approximate", "relative", "unknown", "conflicting"]},
                "subject_entity_local_id": {"anyOf": [{"$ref": "#/$defs/localId"}, {"type": "null"}]},
                "event_local_id": {"anyOf": [{"$ref": "#/$defs/localId"}, {"type": "null"}]}
              }
            }
          }
        }
      ]
    },
    "foreshadowFact": {
      "allOf": [
        {"$ref": "#/$defs/factBase"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["local_id", "fact_kind", "statement", "source", "foreshadowing"],
          "properties": {
            "local_id": true,
            "fact_kind": {"const": "foreshadowing"},
            "statement": true,
            "source": true,
            "supporting_sources": true,
            "foreshadowing": {
              "type": "object",
              "additionalProperties": false,
              "required": ["thread_local_id", "stage", "occurrence_order"],
              "properties": {
                "thread_local_id": {"$ref": "#/$defs/localId"},
                "stage": {"enum": ["planted", "reinforced", "partially_resolved", "resolved", "abandoned"]},
                "event_local_id": {"anyOf": [{"$ref": "#/$defs/localId"}, {"type": "null"}]},
                "occurrence_order": {"type": "number"}
              }
            }
          }
        }
      ]
    },
    "genericFact": {
      "allOf": [
        {"$ref": "#/$defs/factBase"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["local_id", "fact_kind", "statement", "source", "details"],
          "properties": {
            "local_id": true,
            "fact_kind": {"enum": ["world_rule", "relationship"]},
            "statement": true,
            "source": true,
            "supporting_sources": true,
            "details": {"type": "object"}
          }
        }
      ]
    },
    "eventRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_event_local_id", "to_event_local_id", "relation_type", "source", "confidence"],
      "properties": {
        "from_event_local_id": {"$ref": "#/$defs/localId"},
        "to_event_local_id": {"$ref": "#/$defs/localId"},
        "relation_type": {"enum": ["before", "after", "causes", "enables", "blocks", "contradicts", "parallel"]},
        "source": {"$ref": "#/$defs/source"},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "storyArc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_id", "title", "summary", "event_local_ids", "source", "confidence"],
      "properties": {
        "local_id": {"$ref": "#/$defs/localId"},
        "title": {"type": "string", "minLength": 1, "maxLength": 500},
        "summary": {"type": "string", "maxLength": 8000},
        "arc_type": {"type": "string", "maxLength": 200},
        "event_local_ids": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"$ref": "#/$defs/localId"}},
        "source": {"$ref": "#/$defs/source"},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    }
  }
}
