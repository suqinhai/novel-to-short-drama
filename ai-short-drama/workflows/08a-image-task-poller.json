    {
      "parameters": {
        "jsCode": "const max=Number($json.max_poll_count),wait=Number($env.IMAGE_MAX_WAIT_MINUTES||10)*60000,expired=Date.now()-new Date($json.started_at).getTime()>wait;if($json.new_poll_count>=max||expired){$json.new_status='timeout';$json.result={...$json.result,success:false,status:'timeout',error:{code:'IMAGE_TASK_TIMEOUT',message:'poll limit or wait limit exceeded',retryable:false}}}return [{json:$json}];"
      },
