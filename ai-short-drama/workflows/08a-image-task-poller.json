    {
      "parameters": {
        "jsCode": "const t=$('Loop Claimed Tasks').item.json,s=String($json.status||'processing').toLowerCase(),done=['succeeded','completed','success'].includes(s),failed=['failed','error','cancelled'].includes(s),images=$json.images||($json.url?[{url:$json.url}]:[]);if(done&&!images.length)throw new Error('IMAGE_PROVIDER_INVALID_RESPONSE');return [{json:{...t,new_status:done?'succeeded':failed?'failed':'processing',new_poll_count:Number(t.poll_count)+1,result:{success:!failed,provider:t.provider,model:t.model,mode:'async',provider_task_id:t.provider_task_id,status:done?'succeeded':failed?'failed':'processing',images,usage:{image_count:images.length,estimated_cost:0},error:failed?{code:'IMAGE_PROVIDER_INVALID_RESPONSE',message:$json.error||'provider failed',retryable:false}:null,task_id:t.task_id}}}];"
      },
      "id": "08a-http-normalize",
      "name": "Normalize Poll Response",
      "type": "n8n-nodes-base.code",
