      "typeVersion": 2,
      "position": [
        -880,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH candidates AS(SELECT id FROM drama.image_generation_tasks WHERE status='processing' AND(next_poll_at IS NULL OR next_poll_at<=now())AND($1::text IS NULL OR task_id=$1)AND($2::text IS NULL OR project_id=$2)AND started_at>now()-make_interval(mins=>$3)ORDER BY next_poll_at NULLS FIRST LIMIT $4 FOR UPDATE SKIP LOCKED),claimed AS(UPDATE drama.image_generation_tasks t SET next_poll_at=now()+make_interval(secs=>$5)FROM candidates c WHERE t.id=c.id RETURNING t.*)SELECT * FROM claimed;",
        "options": {
          "queryReplacement": "={{[$json.task_id,$json.project_id,Number($env.IMAGE_MAX_WAIT_MINUTES||10),$json.batch_size,Number($env.IMAGE_POLL_INTERVAL_SECONDS||10)]}}"
        }
      },
