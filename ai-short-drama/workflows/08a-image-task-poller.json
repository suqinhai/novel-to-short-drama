      "id": "08a-mock-if",
      "name": "Mock Task?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -220,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "const fs=require('fs'),path=require('path'),crypto=require('crypto'),t=$json,next=Number(t.poll_count)+1;if(next<2)return [{json:{...t,new_status:'processing',new_poll_count:next,result:{success:true,mode:'async',provider_task_id:t.provider_task_id,status:'processing',images:[]}}}];const h=crypto.createHash('sha256').update(t.idempotency_key+':async').digest('hex'),dir=path.join($env.MEDIA_STORAGE_PATH||'/data/storage','provider-responses'),file=`mock_async_${h.slice(0,24)}.svg`,req=t.request_payload||{},w=Number(req.width||1024),hh=Number(req.height||1792);fs.mkdirSync(dir,{recursive:true});const svg=`<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"${w}\" height=\"${hh}\"><rect width=\"100%\" height=\"100%\" fill=\"#${h.slice(0,6)}\"/><text x=\"50%\" y=\"50%\" text-anchor=\"middle\" fill=\"white\" font-size=\"48\">ASYNC MOCK</text></svg>`;fs.writeFileSync(path.join(dir,file),svg);const url=($env.MEDIA_PUBLIC_BASE_URL||'http://localhost:8088').replace(/[/]$/,'')+'/provider-responses/'+file;return [{json:{...t,new_status:'succeeded',new_poll_count:next,result:{success:true,provider:'mock',model:t.model,mode:'async',provider_task_id:t.provider_task_id,status:'succeeded',images:[{url,storage_url:'/data/storage/provider-responses/'+file,width:w,height:hh,seed:parseInt(h.slice(0,8),16),content_hash:h,mime_type:'image/svg+xml',size_bytes:Buffer.byteLength(svg)}],usage:{image_count:1,estimated_cost:0},task_id:t.task_id,error:null}}}];"
      },
