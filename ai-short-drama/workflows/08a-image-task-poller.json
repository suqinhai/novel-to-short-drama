      "id":"08a-webhook","name":"Manual Poll Webhook","type":"n8n-nodes-base.webhook","typeVersion":2.1,"position":[-1100,260],"webhookId":"ai-short-drama-image-poller"
    },
    {
      "parameters": {
        "jsCode": "const b=$json.body||$json;return [{json:{task_id:b.task_id||null,project_id:b.project_id||null,trace_id:b.trace_id||`trace_poll_${Date.now()}`,batch_size:Math.max(1,Math.min(Number($env.IMAGE_POLLER_BATCH_SIZE||10),50))}}];"
