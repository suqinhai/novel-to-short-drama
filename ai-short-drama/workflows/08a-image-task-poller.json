    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH t AS(UPDATE drama.image_generation_tasks SET status=$1,poll_count=$2,response_payload=$3::jsonb,next_poll_at=CASE WHEN $1='processing'THEN now()+make_interval(secs=>$4)ELSE NULL END,completed_at=CASE WHEN $1 IN('succeeded','failed','timeout')THEN now()ELSE completed_at END,error_code=$5,error_message=$6 WHERE task_id=$7 RETURNING *),a AS(UPDATE drama.generated_assets SET status=$1,original_url=$3::jsonb#>>'{images,0,url}',storage_url=$3::jsonb#>>'{images,0,storage_url}',width=coalesce(($3::jsonb#>>'{images,0,width}')::int,width),height=coalesce(($3::jsonb#>>'{images,0,height}')::int,height),content_hash=coalesce($3::jsonb#>>'{images,0,content_hash}',content_hash),error_code=$5,error_message=$6 WHERE asset_id=(SELECT asset_id FROM t)RETURNING asset_id),im AS(UPDATE drama.storyboard_images SET status=$1,image_url=$3::jsonb#>>'{images,0,url}',storage_url=$3::jsonb#>>'{images,0,storage_url}',auto_qc_status=CASE WHEN $1='succeeded'THEN'passed'WHEN $1 IN('failed','timeout')THEN'failed'ELSE auto_qc_status END,auto_qc_report=CASE WHEN $1='succeeded'THEN jsonb_build_object('status','passed','checks',jsonb_build_object('file_valid',true,'mime_valid',true,'resolution_valid',true,'aspect_ratio_valid',true,'duplicate_detected',false),'warnings','[]'::jsonb)ELSE auto_qc_report END WHERE image_asset_id=(SELECT asset_id FROM t)RETURNING *),rv AS(INSERT INTO drama.review_tasks(review_id,project_id,stage,entity_type,entity_id,review_status,metadata)SELECT 'review_'||substr(md5(storyboard_image_id),1,20),project_id,'storyboard_image','storyboard_image',storyboard_image_id,'pending',jsonb_build_object('shot_id',shot_id,'generation_version',generation_version)FROM im WHERE $1='succeeded'ON CONFLICT(review_id)DO NOTHING)SELECT task_id,status FROM t;",
        "options": {
          "queryReplacement": "={{[$json.new_status,$json.new_poll_count,JSON.stringify($json.result),Number($env.IMAGE_POLL_INTERVAL_SECONDS||10),$json.result.error?.code||null,$json.result.error?.message||null,$json.task_id]}}"
        }
      },
