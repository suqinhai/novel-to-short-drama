# Legacy file-based setup. The recommended setup is now the CMS AI configuration page.
VEO_ADAPTER_HOST_PORT=8091
VIDEO_API_KEY=replace_with_a_long_random_video_adapter_token
VEO_SERVICE_ACCOUNT_JSON=
VEO_PROJECT_ID=
VEO_LOCATION=us-central1
VIDEO_MODEL=veo-3.1-fast-generate-001
VEO_OUTPUT_MODE=local
VEO_GCS_OUTPUT_URI=
VEO_LOCAL_VIDEO_MAX_MB=128
VEO_ADAPTER_PUBLIC_BASE_URL=http://veo-adapter:8091
VEO_IMAGE_URL_REWRITE_FROM=http://localhost:8088
VEO_IMAGE_URL_REWRITE_TO=http://media
VEO_IMAGE_ALLOWED_HOSTS=media,localhost,127.0.0.1,host.docker.internal
VEO_IMAGE_MAX_MB=20
VEO_PERSON_GENERATION=allow_adult
VEO_ENHANCE_PROMPT=true
VEO_RESIZE_MODE=crop
VEO_MEDIA_URL_TTL_SECONDS=86400
